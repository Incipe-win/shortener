Name: shortener-api
Host: 0.0.0.0
Port: 8888
ShortUrlDB:
  DSN: root:root@tcp(127.0.0.1:3306)/sql_test?charset=utf8mb4&parseTime=True&loc=Local
Sequence:
  DSN: root:root@tcp(127.0.0.1:3306)/sql_test?charset=utf8mb4&parseTime=True&loc=Local
CacheRedis:
  - Host: 127.0.0.1:6379
BaseString: J0rs12O5TUV8IW7D9aBdXeCfghiMQj3klmop6qtuvbcwx4zAEFGHKLNnPRYSZy
ShortUrlBlackList:
  ["version", "fuxk", "stupid", "convert", "health", "api", "css", "js", "preview", "metrics"]
ShortDoamin: shortener.com

# LLM 大模型配置
LLM:
  Enabled: True
  BaseURL: "https://api.deepseek.com"
  APIKey: "${LLM_API_KEY}"
  Model: "deepseek-chat"

# 安全巡检配置
Safety:
  Enabled: true
  BlackListDomains: []

# 可观测性配置
Otel:
  Name: "shortener-api"
  Endpoint: ""
  Sampler: 1.0
